# Copy to .env and fill in values. Never commit .env.

# --- Runtime ---
NODE_ENV=development

# --- PostgreSQL ---
POSTGRES_USER=recipes
POSTGRES_PASSWORD=change_me
POSTGRES_DB=recipesdb

# Kubernetes: create the cluster Secret from a file (see k8s/secret.env.example → k8s/secret.env),
# then `kubectl create secret ... --from-env-file=k8s/secret.env` (documented in k8s/how-to).

# --- Backend API (recipes-service) ---
# JWT token signing secret — same value as JWT_SECRET in k8s/secret.env if you use Compose + kind.
# Used by recipes-service for authentication tokens. Generate: openssl rand -hex 32
JWT_SECRET=
# Optional: Google OAuth login (free). Redirect URI in Google must be:
#   <PUBLIC_APP_URL>/api/auth/google/callback
# Example for local Compose: http://localhost:3000/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: stricter JWTs in production (set both; users must log in again after change)
# JWT_ISSUER=https://your-api.example.com
# JWT_AUDIENCE=get-cookin-web

# Session length (cookie maxAge matches JWT expiry)
JWT_EXPIRES_DAYS=7

# httpOnly auth cookie (default name: token). If you change this, update Next.js API routes that forward cookies.
# AUTH_COOKIE_NAME=token

# Cookie flags: in production, secure defaults to true (HTTPS only).
# JWT_COOKIE_SECURE=false
# JWT_COOKIE_SAMESITE=lax

# Optional: parent domain for cookie, e.g. .example.com
# AUTH_COOKIE_DOMAIN=

# Behind reverse proxy (nginx, Railway, etc.)
# TRUST_PROXY=true

# Logging: debug | info | warn | error (default info). Kubernetes manifest sets debug+line for recipes-service in kind.
# LOG_LEVEL=info
# line = human-readable; json = one JSON object per line (default json in production, line in development)
# LOG_FORMAT=line

# --- MinIO (optional — only when recipes-service has MINIO_* set; see k8s Helm chart / README) ---
# MINIO_ENDPOINT=minio
# MINIO_PORT=9000
# MINIO_USE_SSL=false
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=change_me_minio
# MINIO_BUCKET=recipe-images

# --- Frontend (Docker server-side proxy only) ---
# Base URL of API including /api path (used by Next.js API routes in container)
API_URL=http://recipes-service:4000/api

# Optional Google Analytics 4 measurement ID (G-xxxxxxxxxx). If set, the site shows a GDPR-style
# cookie banner; GA loads only after the user accepts. Leave empty to disable analytics.
# GA_MEASUREMENT_ID=

# --- PgAdmin (optional; not started unless profile is used) ---
# Start with: docker compose --profile tools up -d
# Then open http://127.0.0.1:5050 — DB host in UI: postgres, port 5432
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=change_me
