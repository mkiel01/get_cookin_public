# Copy to k8s/monitoring.secret.env (gitignored).
#
# kube-prometheus-stack / Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
#
# Server Mac (get-cookin Kind) Tailscale IP — used when generating
# k8s/helm/monitoring/values-remote-scrape-server.yaml from values-remote-scrape-server.template.yaml
# (see docs/monitoring-remote-scrape-getcookin.md).
SERVER_TAILSCALE_IP=
#
# Monitoring Mac (kind-monitoring) Tailscale IP — Zabbix Server + kube-prometheus-stack; required when generating
# k8s/helm/zabbix/values-getcookin-zabbix-agent.yaml from values-getcookin-zabbix-agent.template.yaml (see k8s/zabbix/README.md).
# Also used as FLUENT_ES_HOST on the Server Mac so Fluentd ships logs to Elasticsearch (NodePort 30200) — docs/logging-elk.md
MONITORING_TAILSCALE_IP=
#
# zabbix-community Helm chart — chart version + PostgreSQL credentials (postgresAccess.*).
# Do not commit real passwords. Used with: helm --set postgresAccess.user=... password=...
ZABBIX_CHART_VERSION=7.0.12
ZABBIX_POSTGRES_USER=zabbix
ZABBIX_POSTGRES_PASSWORD=change-me-zabbix-db
