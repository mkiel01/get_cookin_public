# Optional: copy to k8s/zabbix/inventory.env (gitignored) or add these keys to k8s/monitoring.secret.env
#
# Used when generating values-getcookin-zabbix-agent.yaml — agents need the Monitoring Mac Tailscale IP.

# Monitoring Mac (kind-monitoring) — Zabbix Server + Grafana/Prometheus live here
MONITORING_TAILSCALE_IP=

# Server Mac (kind-get-cookin) — get-cookin app + Zabbix agents; referenced in docs / firewall notes
SERVER_TAILSCALE_IP=

# Zabbix Server trapper for active checks (must match zabbixServer.service.nodePort on Monitoring cluster, default 31051)
# ZABBIX_SERVER_ACTIVE="${MONITORING_TAILSCALE_IP}:31051"
