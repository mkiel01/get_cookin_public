# Copy to k8s/secret.env (gitignored), replace placeholders, never commit real values.
#
# Apply the Secret (native kubectl — no extra tools):
#   kubectl create secret generic get-cookin-secrets \
#     --namespace=get-cookin \
#     --from-env-file=k8s/secret.env \
#     --dry-run=client -o yaml | kubectl apply -f -
#
# DATABASE_URL host must be "postgres" (Service name in-cluster). Password in the URL
# must match POSTGRES_PASSWORD.
#
# JWT — must match repo root .env (Compose recipes-service uses JWT_SECRET from .env).
# Same string in both places so tokens/cookies work across Docker Compose and Kubernetes.
# Generate: openssl rand -hex 32 — do not commit real values to git.

POSTGRES_USER=recipes
POSTGRES_PASSWORD=change_me
POSTGRES_DB=recipesdb
DATABASE_URL=postgres://recipes:change_me@postgres:5432/recipesdb
JWT_SECRET=

# MinIO (required for the Helm chart / recipes-service MINIO_* env). Same values as MinIO root login.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio

# Optional: recipes-service rate limits (defaults are fine for normal UI use).
# RATE_LIMIT_MAX=4000
# RATE_LIMIT_AUTH_MAX=50

# Password reset emails (recipes-service). PUBLIC_APP_URL = browser origin for reset links (no trailing slash).
# Example: https://getcookin.online or http://localhost:3000
# PUBLIC_APP_URL=https://your-domain.example
# SMTP_FROM=noreply@your-domain.example
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# Optional: Google OAuth login (free). Create credentials in Google Cloud Console:
# redirect URI must be: <PUBLIC_APP_URL>/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Optional: reset link lifetime in minutes (default 60, max 1440).
# PASSWORD_RESET_EXPIRES_MINUTES=60
# EMAIL_VERIFICATION_EXPIRES_HOURS is currently unused (email verification disabled).

# --- Save as k8s/secret.env, apply with kubectl (see top). Do not commit k8s/secret.env. ---
