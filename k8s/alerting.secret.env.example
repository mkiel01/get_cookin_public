# Optional split: copy to k8s/alerting.secret.env (gitignored).
# Use this if you want Zabbix DB secrets separate from k8s/monitoring.secret.env.
# Before helm install zabbix, run:
#   set -a && source k8s/monitoring.secret.env && source k8s/alerting.secret.env && set +a
# (or only source alerting.secret.env if Grafana vars are not needed for that shell).
#
ZABBIX_CHART_VERSION=7.0.12
ZABBIX_POSTGRES_USER=zabbix
ZABBIX_POSTGRES_PASSWORD=change-me-zabbix-db
#
# Optional website analytics (Google Analytics 4).
# One measurement ID for the whole site/property (not per user), e.g. G-XXXXXXXXXX.
# Used by frontend cookie-consent flow; leave empty to disable analytics.
GA_MEASUREMENT_ID=G-0KBGJB2S45
#
# Template import Job (k8s/zabbix/automation/) uses Secret zabbix-api-import — not this file.
# kubectl create secret generic zabbix-api-import -n zabbix --from-literal=password='ZABBIX_WEB_ADMIN_PASSWORD'
